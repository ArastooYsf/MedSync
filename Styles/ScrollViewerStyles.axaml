<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MedSync.ViewModels"
        x:DataType="vm:MainViewModel">

    <Design.PreviewWith>
        <Border Padding="20"
                Background="{DynamicResource PrimaryBackground}"
                BorderBrush="{DynamicResource BlueBrush}"
                BorderThickness="2"
                CornerRadius="4">
            <StackPanel Spacing="10">

                <ScrollViewer VerticalScrollBarVisibility="Visible" MaxHeight="150">
                    <StackPanel>
                        <Button>
                            <Label>banana</Label>
                        </Button>
                        <Button>
                            <Label>banana</Label>
                        </Button>
                        <Button>
                            <Label>banana</Label>
                        </Button>
                        <Button>
                            <Label>banana</Label>
                        </Button>
                        <Button>
                            <Label>banana</Label>
                        </Button>
                        <Button>
                            <Label>banana</Label>
                        </Button>
                        <Button>
                            <Label>banana</Label>
                        </Button>
                        <Button>
                            <Label>banana</Label>
                        </Button>
                        <Button>
                            <Label>banana</Label>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <!-- Scroll Viewer -->

    <Style Selector="ScrollViewer">
        <Setter Property="AllowAutoHide" Value="False" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>

    <Style Selector="ScrollBar:vertical /template/ Border#VerticalRoot">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BoxShadow" Value="inset 0 0 10 0 Black" />
        <Setter Property="CornerRadius" Value="50" />
    </Style>

    <Style Selector="ScrollBar:vertical /template/ Rectangle#TrackRect">
        <Setter Property="Fill" Value="Transparent" />
    </Style>

    <Style Selector="ScrollBar:vertical /template/ Thumb">
        <Setter Property="Template">
            <ControlTemplate>
                <Grid Margin="5">
                    <Border Background="{DynamicResource BlueBrush}" CornerRadius="50" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="ScrollBar:vertical /template/ RepeatButton">
        <Setter Property="IsVisible" Value="False" />
    </Style>

    <!-- Animation -->

</Styles>
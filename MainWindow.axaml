<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="600"
        MinWidth="400" MinHeight="300"
        x:Class="MedSync.MainWindow"
        Title="MedSync">

    <Grid ShowGridLines="True" Background="{DynamicResource PrimaryBackground}" ColumnDefinitions="3*,*">
        <Border Grid.Column="1" Padding="10">
            <Border Background="#212930"
                    CornerRadius="8">
                <Grid RowDefinitions="*,Auto">
                    <StackPanel Grid.Row="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,20,0,0"
                                Spacing="12">
                        <Image Source="{SvgImage /Assets/Images/Logo.svg}"
                               Width="100"
                               MaxWidth="150"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"/>
                        <Border>
                            <Button Content="خانه"/>
                        </Border>
                        <Border>
                            <Button Content="خانه"/>
                        </Border>
                        <Border>
                            <Button Content="خانه"/>
                        </Border>
                        <Border>
                            <Button Content="خانه"/>
                        </Border>
                    </StackPanel>
                    <Border Grid.Row="1">
                        <Button></Button>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
    
</Window>